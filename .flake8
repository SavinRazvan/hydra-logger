[flake8]
# Match black default line length; E501 ignored here because black owns wrapping
# (long string literals may still exceed 88 cols).
max-line-length = 88
extend-ignore = E203, W503, E501
exclude =
    .git,
    __pycache__,
    .hydra_env,
    .tmp_tools,
    build,
    dist,
    performance_benchmark.py
