{
  "hydra_config_schema_version": 1,
  "default_level": "DEBUG",
  "base_log_dir": "examples/logs",
  "log_dir_name": "notebooks",
  "layers": {
    "app": {
      "level": "DEBUG",
      "destinations": [
        {
          "type": "console",
          "format": "colored",
          "use_colors": true
        },
        {
          "type": "file",
          "path": "dev_app",
          "format": "json-lines"
        }
      ]
    }
  }
}
